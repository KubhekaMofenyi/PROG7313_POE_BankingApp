<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF3E4">

    <LinearLayout
        android:id="@+id/splashContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:background="@drawable/bg_card_white"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingTop="42dp"
        android:paddingEnd="28dp"
        android:paddingBottom="42dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/imgSplashLogo"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:contentDescription="Zentavo Logo"
            android:scaleType="centerInside"
            android:src="@drawable/zentavo_logo" />

        <TextView
            android:id="@+id/tvSplashName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Zentavo"
            android:textColor="#8F1E0C"
            android:textSize="36sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSplashTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Track. Plan. Grow."
            android:textColor="#5F5F5F"
            android:textSize="16sp" />

        <View
            android:id="@+id/loadingBar"
            android:layout_width="90dp"
            android:layout_height="6dp"
            android:layout_marginTop="30dp"
            android:background="#D97A18" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>